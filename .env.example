# Copy this file to ".env" and fill in your key.
# Get a key at https://developer.riotgames.com  (Development keys expire every 24h)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your server. Platform routing (na1, euw1, eun1, kr, br1, jp1, oc1, ...)
TFT_PLATFORM=na1

# Regional cluster used for account + match lookups: americas | europe | asia | sea
TFT_REGION=americas
